generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  name      String?
  createdAt DateTime  @default(now())
  plans     Plan[]
}

model Plan {
  id          Int       @id @default(autoincrement())
  title       String
  description String
  level       String
  goal        String
  daysPerWeek Int       @default(3)  // ← ОБЯЗАТЕЛЬНО
  user        User?     @relation(fields: [userId], references: [id])
  userId      Int?
  workouts    Workout[]
}

model Workout {
  id          Int        @id @default(autoincrement())
  title       String
  description String
  plan        Plan?      @relation(fields: [planId], references: [id])
  planId      Int?
  exercises   Exercise[]
}

model Exercise {
  id          Int      @id @default(autoincrement())
  name        String
  muscleGroup String
  equipment   String
  level       String
  description String
  sets        Int
  reps        Int
  workout     Workout? @relation(fields: [workoutId], references: [id])
  workoutId   Int?
}


model TrainingPlan {
  id        Int        @id @default(autoincrement())
  name      String
  createdAt DateTime   @default(now())
  days      PlanDay[]
}

model PlanDay {
  id            Int          @id @default(autoincrement())
  plan          TrainingPlan @relation(fields: [planId], references: [id])
  planId        Int
  dayKey        String       // mon, tue, wed, thu, fri, sat, sun
  title         String
  focus         String
  intensity     String
  duration      String
  isRest        Boolean      @default(false)
  exercises     PlanExercise[]
}

model PlanExercise {
  id       Int     @id @default(autoincrement())
  day      PlanDay @relation(fields: [dayId], references: [id])
  dayId    Int
  name     String
  order    Int
}